{
  "name": "curro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agente de IA local con Telegram, Groq, memoria SQLite y arquitectura modular.",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "dotenv": "^16.4.7",
    "firebase-admin": "^13.5.0",
    "grammy": "^1.36.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  }
}
